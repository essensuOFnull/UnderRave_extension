{
	"manifest_version": 3,
	"name": "刀口亼右户仨亼レ仨",
	"version": "3.2.0",
	"description": "Набор улучшений для сайтов и браузера Google Chrome, разработанный для членов Подбредья.",
	"permissions": [
		"tabs",
		"scripting",
		"activeTab",
		"declarativeNetRequest",
		"storage",
		"contextMenus",
		"tabCapture",
        "desktopCapture"
	],
	"host_permissions": [
		"<all_urls>"
	],
	"web_accessible_resources": [{
		"resources": [
			"web_accessible_resources/**/*",
			"styles/nyx.css"
		],
		"matches": ["<all_urls>"]
	}],
	"action": {
		"default_icon": {
			"16": "icon.png",
			"48": "icon.png",
			"128": "icon.png"
		}
	},
	"background": {
		"service_worker": "background.js",
		"type": "module"
	},
	"icons": {
		"16": "icon.png",
		"48": "icon.png",
		"128": "icon.png"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": [
				"contents/context_menu.js",
				"contents/video_search.js",
				"contents/lifting_restrictions.js",
				"contents/pip_handler.js",
				"contents/media_mixer.js"
			],
			"run_at": "document_start",
			"all_frames": true
		},
		{
			"matches": ["*://nyx-app.ru/*"],
			"js": ["contents/nyx.js"],
			"css": ["styles/nyx.css"],
			"run_at": "document_end",
			"all_frames": true
		}
	]
}