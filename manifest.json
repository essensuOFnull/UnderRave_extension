{
	"manifest_version": 3,
	"name": "刀口亼右户仨亼レ仨",
	"version": "0.1.0",
	"description": "Набор улучшений для сайтов и браузера Google Chrome, разработанный для членов Подбредья.",
	"permissions": [
		"tabs",
		"scripting"
	],
	"host_permissions": [
  		"<all_urls>"
	],
	"web_accessible_resources": [{
		"resources": ["scripts/*.js"],
		"matches": ["<all_urls>"]
	}],
	"action": {
		"default_popup": "popup.html",
		"default_icon": {
			"16": "icons/icon.png",
			"48": "icons/icon.png",
			"128": "icons/icon.png"
		}
	},
	"background": {
		"service_worker": "background.js",
		"type": "module"
	},
	"icons": {
		"16": "icons/icon.png",
		"48": "icons/icon.png",
		"128": "icons/icon.png"
	}
}